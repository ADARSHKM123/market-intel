{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["backend/src/index.js"],
      "port": 3001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--config", "frontend/vite.config.js"],
      "port": 5173
    },
    {
      "name": "nlp-service",
      "runtimeExecutable": "nlp-service/.venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--port", "8001", "--app-dir", "nlp-service"],
      "port": 8001
    }
  ]
}
